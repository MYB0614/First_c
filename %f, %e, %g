#include <stdio.h>

int main()
{
    double num_1 = 0.1234;
    double num_2 = 0.12345678;
    
    double d1 = 1.23e-3;
    double d2 = 1.23e-4;
    double d3 = 1.23e-5;
    double d4 = 1.23e-6;
    
    printf("%f\n",num_1);
    printf("%e\n",num_1);
    printf("%f\n",num_2);
    printf("%e\n",num_2);
    printf("-----------------\n");
    
    printf("%g\n",d1);
    printf("%g\n",d2);
    printf("%g\n",d3);
    printf("%g\n",d4);      // %g는 소수점 이하 자릿수에 따라 %e와 %f 와리가리함~!
    
    return 0;
        

}
