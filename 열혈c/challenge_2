#include <stdio.h>
#define SIZE 10



// 1.c
void odd(int *ptr){
    printf("홀수출력 : ");
    for(int i =0; i< SIZE; i++){
        if(*(ptr+i)%2 != 0){
            printf("%d ",*(ptr+i));
        }
    }
    printf("\n");
}

void even(int *ptr){
    printf("짝수출력 : ");
    for(int i =0; i< SIZE; i++){
        if(*(ptr+i)%2 == 0){
            printf("%d ",*(ptr+i));
        }
    }
    printf("\n");
    
}


int main(void){
    int arr[SIZE];
    
    for (int i = 0; i < SIZE; i++){
        printf("입력: ");
        scanf("%d",&arr[i]);
    }
    
    odd(arr);
    even(arr);
    return 0;
}
